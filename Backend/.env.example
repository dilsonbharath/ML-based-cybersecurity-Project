DATABASE_URL=postgresql://username:password@host/database?sslmode=require
# Optional Vercel-provided alternatives (if DATABASE_URL is not set):
# POSTGRES_URL=postgresql://...
# POSTGRES_PRISMA_URL=postgresql://...
# POSTGRES_URL_NON_POOLING=postgresql://...

# Comma-separated frontend origins allowed by CORS in production.
# Example: CORS_ORIGINS=https://your-frontend.vercel.app,https://app.example.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Remote ML scoring service used by admin security endpoints.
ML_SERVICE_URL=http://127.0.0.1:8100
ML_SERVICE_TIMEOUT=10
